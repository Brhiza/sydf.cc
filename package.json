{
  "name": "sydf-vue3",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "vite",
    "dev:oyyy": "vite --mode oyyy",
    "build": "npm run clean && vite build && npm run prerender",
    "prerender": "tsx scripts/prerender.ts",
    "oyyy": "npm run clean && vite build --mode oyyy && npm run prerender -- --custom-build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint . --ext .vue,.js,.ts",
    "lint:fix": "npm run lint -- --fix",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "format": "prettier --write \"src/**/*.{vue,ts,css,md}\""
  },
  "dependencies": {
    "marked": "^18.0.5",
    "mingyu-core": "^0.1.14",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260705.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "sharp": "^0.35.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.45.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.3",
    "vite-plugin-compression2": "^2.2.1",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "@rollup/plugin-terser": "^1.0.0"
  }
}
